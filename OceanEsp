local Tab = Window:CreateTab("Esp", 4483362458)
local Section = Tab:CreateSection("Esp")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = game:GetService("Workspace").CurrentCamera

local Toggle1 = Tab:CreateToggle({
   Name = "ESP Name",
   CurrentValue = false,
   Flag = "EspNameFlag", 
   Callback = function(Value)
       _G.EspNameActive = Value
       if _G.EspNameActive then
           task.spawn(function()
               while _G.EspNameActive do
                   for _, player in pairs(Players:GetPlayers()) do
                       if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
                           if not player.Character.Head:FindFirstChild("EspTag") then
                               local bbg = Instance.new("BillboardGui", player.Character.Head)
                               bbg.Name = "EspTag"
                               bbg.AlwaysOnTop = true
                               bbg.Size = UDim2.new(0, 100, 0, 50)
                               bbg.StudsOffset = Vector3.new(0, 3, 0)
                               local label = Instance.new("TextLabel", bbg)
                               label.BackgroundTransparency = 1
                               label.Size = UDim2.new(1, 0, 1, 0)
                               label.Text = player.Name
                               label.TextColor3 = Color3.new(1, 1, 1)
                               label.TextStrokeTransparency = 0
                               label.TextSize = 14
                           end
                       end
                   end
                   task.wait(1)
               end
           end)
       else
           for _, player in pairs(Players:GetPlayers()) do
               if player.Character and player.Character:FindFirstChild("Head") then
                   local tag = player.Character.Head:FindFirstChild("EspTag")
                   if tag then tag:Destroy() end
               end
           end
       end
   end,
})

local Toggle2 = Tab:CreateToggle({
   Name = "ESP Hitbox",
   CurrentValue = false,
   Flag = "EspHitboxFlag", 
   Callback = function(Value)
       _G.EspHitboxActive = Value
       if _G.EspHitboxActive then
           task.spawn(function()
               while _G.EspHitboxActive do
                   for _, player in pairs(Players:GetPlayers()) do
                       if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                           local char = player.Character
                           local hrp = char.HumanoidRootPart
                           if not hrp:FindFirstChild("BoxHitbox") then
                               local box = Instance.new("BoxHandleAdornment")
                               box.Name = "BoxHitbox"
                               box.Size = char:GetExtentsSize() + Vector3.new(0.5, 0.5, 0.5)
                               box.AlwaysOnTop = true
                               box.ZIndex = 5
                               box.Transparency = 0.5
                               box.Color3 = Color3.fromRGB(255, 0, 0)
                               box.Adornee = hrp
                               box.Parent = hrp
                           end
                       end
                   end
                   task.wait(1)
               end
           end)
       else
           for _, player in pairs(Players:GetPlayers()) do
               if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                   local box = player.Character.HumanoidRootPart:FindFirstChild("BoxHitbox")
                   if box then box:Destroy() end
               end
           end
       end
   end,
})

local Toggle3 = Tab:CreateToggle({
   Name = "ESP Distance",
   CurrentValue = false,
   Flag = "EspDistanceFlag", 
   Callback = function(Value)
       _G.EspDistanceActive = Value
       if _G.EspDistanceActive then
           task.spawn(function()
               while _G.EspDistanceActive do
                   for _, player in pairs(Players:GetPlayers()) do
                       if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
                           local head = player.Character.Head
                           local tag = head:FindFirstChild("DistanceTag")
                           if not tag then
                               local bbg = Instance.new("BillboardGui", head)
                               bbg.Name = "DistanceTag"
                               bbg.AlwaysOnTop = true
                               bbg.Size = UDim2.new(0, 100, 0, 50)
                               bbg.StudsOffset = Vector3.new(0, 4.5, 0)
                               local label = Instance.new("TextLabel", bbg)
                               label.Name = "DistLabel"
                               label.BackgroundTransparency = 1
                               label.Size = UDim2.new(1, 0, 1, 0)
                               label.TextColor3 = Color3.fromRGB(0, 255, 150)
                               label.TextStrokeTransparency = 0
                               label.TextSize = 12
                               tag = bbg
                           end
                           local distance = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")) and 
                                            (player.Character:FindFirstChild("HumanoidRootPart")) and 
                                            math.floor((LocalPlayer.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude) or 0
                           if tag:FindFirstChild("DistLabel") then
                               tag.DistLabel.Text = "[" .. tostring(distance) .. " studs]"
                           end
                       end
                   end
                   task.wait(0.1)
               end
           end)
       else
           for _, player in pairs(Players:GetPlayers()) do
               if player.Character and player.Character:FindFirstChild("Head") then
                   local tag = player.Character.Head:FindFirstChild("DistanceTag")
                   if tag then tag:Destroy() end
               end
           end
       end
   end,
})

